        \PYG{c+c1}{\PYGZsh{} encoder part}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc1} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{x\PYGZus{}dim}\PYG{p}{,} \PYG{n}{h\PYGZus{}dim1}\PYG{p}{)}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc2} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{h\PYGZus{}dim1}\PYG{p}{,} \PYG{n}{h\PYGZus{}dim2}\PYG{p}{)}
        \PYG{c+c1}{\PYGZsh{} decoder part}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc3} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{h\PYGZus{}dim2}\PYG{p}{,} \PYG{n}{h\PYGZus{}dim1}\PYG{p}{)}
