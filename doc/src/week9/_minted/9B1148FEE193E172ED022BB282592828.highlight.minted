            \PYG{n}{predictions} \PYG{o}{=} \PYG{n}{model}\PYG{p}{(}\PYG{n}{X\PYGZus{}batch}\PYG{p}{)}
            \PYG{n}{loss} \PYG{o}{=} \PYG{n}{criterion}\PYG{p}{(}\PYG{n}{predictions}\PYG{p}{,} \PYG{n}{y\PYGZus{}batch}\PYG{p}{)}

