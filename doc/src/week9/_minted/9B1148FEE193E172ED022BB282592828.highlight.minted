        \PYG{k}{with} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{no\PYGZus{}grad}\PYG{p}{(}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{for} \PYG{n}{X\PYGZus{}batch}\PYG{p}{,} \PYG{n}{y\PYGZus{}batch} \PYG{o+ow}{in} \PYG{n}{test\PYGZus{}loader}\PYG{p}{:}
                \PYG{n}{X\PYGZus{}batch} \PYG{o}{=} \PYG{n}{X\PYGZus{}batch}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{,} \PYG{n}{non\PYGZus{}blocking}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
                \PYG{n}{y\PYGZus{}batch} \PYG{o}{=} \PYG{n}{y\PYGZus{}batch}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{,} \PYG{n}{non\PYGZus{}blocking}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}

