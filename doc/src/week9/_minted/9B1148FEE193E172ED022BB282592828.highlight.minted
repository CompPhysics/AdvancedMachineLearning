                \PYG{n}{vl} \PYG{o}{+}\PYG{o}{=} \PYG{n}{lat\PYGZus{}criterion}\PYG{p}{(}\PYG{n}{pred}\PYG{p}{,} \PYG{n}{z\PYGZus{}target}\PYG{p}{)}\PYG{o}{.}\PYG{n}{item}\PYG{p}{(}\PYG{p}{)}
