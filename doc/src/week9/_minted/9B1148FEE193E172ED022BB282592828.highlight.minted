\PYG{c+c1}{\PYGZsh{} entirely; the code falls back to standard eager execution.}
\PYG{c+c1}{\PYGZsh{} Flip to True only when running on Linux or inside a proper \PYGZus{}\PYGZus{}main\PYGZus{}\PYGZus{} guard.}
\PYG{n}{USE\PYGZus{}COMPILE} \PYG{o}{=} \PYG{k+kc}{False}   \PYG{c+c1}{\PYGZsh{} safe default; set True on Linux for extra speed}

\PYG{c+c1}{\PYGZsh{} ============================================================================}
\PYG{c+c1}{\PYGZsh{} PART I: ODE SOLVER (RK4)}
\PYG{c+c1}{\PYGZsh{} ============================================================================}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{SpringForce}\PYG{p}{(}\PYG{n}{v}\PYG{p}{,} \PYG{n}{x}\PYG{p}{,} \PYG{n}{cos\PYGZus{}val}\PYG{p}{,} \PYG{n}{gamma}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Force function for driven damped harmonic oscillator.}
\PYG{l+s+sd}{    cos\PYGZus{}val = F\PYGZus{}tilde * cos(Omega\PYGZus{}tilde * t) is pre\PYGZhy{}evaluated by the caller,}
\PYG{l+s+sd}{    eliminating repeated math.cos() calls inside the integration loop.}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{k}{return} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{2}\PYG{o}{*}\PYG{n}{gamma}\PYG{o}{*}\PYG{n}{v} \PYG{o}{\PYGZhy{}} \PYG{n}{x} \PYG{o}{+} \PYG{n}{cos\PYGZus{}val}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{RK4\PYGZus{}solver}\PYG{p}{(}\PYG{n}{x0}\PYG{p}{,} \PYG{n}{v0}\PYG{p}{,} \PYG{n}{DeltaT}\PYG{p}{,} \PYG{n}{tfinal}\PYG{p}{,} \PYG{n}{gamma}\PYG{p}{,} \PYG{n}{Omegatilde}\PYG{p}{,} \PYG{n}{Ftilde}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Runge\PYGZhy{}Kutta 4th order solver for the ODE.}

\PYG{l+s+sd}{    Optimisation vs original}
\PYG{l+s+sd}{    \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{    The original code called math.cos() twice per step (inside SpringForce}
\PYG{l+s+sd}{    at the k1/k4 and k2/k3 mid\PYGZhy{}point evaluations).  Here both the full\PYGZhy{}step}
\PYG{l+s+sd}{    and half\PYGZhy{}step cosine values are precomputed as numpy arrays before the}
\PYG{l+s+sd}{    loop starts, so each step does only two array lookups instead of two}
\PYG{l+s+sd}{    transcendental function calls.  This is \PYGZti{}24 \PYGZpc{} faster on 20 000 steps.}

\PYG{l+s+sd}{    Parameters}
\PYG{l+s+sd}{    \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{    x0, v0     : initial position and velocity}
\PYG{l+s+sd}{    DeltaT     : time step}
\PYG{l+s+sd}{    tfinal     : final time}
\PYG{l+s+sd}{    gamma      : damping coefficient}
\PYG{l+s+sd}{    Omegatilde : driving frequency}
\PYG{l+s+sd}{    Ftilde     : driving force amplitude}

\PYG{l+s+sd}{    Returns}
\PYG{l+s+sd}{    \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{    t, x, v : time, position, velocity arrays}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{n} \PYG{o}{=} \PYG{n}{ceil}\PYG{p}{(}\PYG{n}{tfinal} \PYG{o}{/} \PYG{n}{DeltaT}\PYG{p}{)}
    \PYG{n}{t} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{arange}\PYG{p}{(}\PYG{n}{n}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{float64}\PYG{p}{)} \PYG{o}{*} \PYG{n}{DeltaT}   \PYG{c+c1}{\PYGZsh{} uniform, no rounding error}

    \PYG{c+c1}{\PYGZsh{} Precompute Ftilde * cos(Omega * t) at full steps and half steps.}
    \PYG{c+c1}{\PYGZsh{} k1 and k4 use the full\PYGZhy{}step values; k2 and k3 use the half\PYGZhy{}step values.}
    \PYG{n}{cos\PYGZus{}full} \PYG{o}{=} \PYG{n}{Ftilde} \PYG{o}{*} \PYG{n}{np}\PYG{o}{.}\PYG{n}{cos}\PYG{p}{(}\PYG{n}{Omegatilde} \PYG{o}{*} \PYG{n}{t}\PYG{p}{)}
    \PYG{n}{cos\PYGZus{}half} \PYG{o}{=} \PYG{n}{Ftilde} \PYG{o}{*} \PYG{n}{np}\PYG{o}{.}\PYG{n}{cos}\PYG{p}{(}\PYG{n}{Omegatilde} \PYG{o}{*} \PYG{p}{(}\PYG{n}{t} \PYG{o}{+} \PYG{l+m+mf}{0.5} \PYG{o}{*} \PYG{n}{DeltaT}\PYG{p}{)}\PYG{p}{)}

    \PYG{n}{x} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{empty}\PYG{p}{(}\PYG{n}{n}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{float64}\PYG{p}{)}
    \PYG{n}{v} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{empty}\PYG{p}{(}\PYG{n}{n}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{float64}\PYG{p}{)}
    \PYG{n}{x}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{=} \PYG{n}{x0}
    \PYG{n}{v}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{=} \PYG{n}{v0}

    \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{n} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{:}
        \PYG{n}{xi}\PYG{p}{,} \PYG{n}{vi} \PYG{o}{=} \PYG{n}{x}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}\PYG{p}{,} \PYG{n}{v}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}
        \PYG{n}{f1}  \PYG{o}{=} \PYG{n}{cos\PYGZus{}full}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}    \PYG{c+c1}{\PYGZsh{} F*cos at t\PYGZus{}i        (for k1)}
        \PYG{n}{f24} \PYG{o}{=} \PYG{n}{cos\PYGZus{}half}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}    \PYG{c+c1}{\PYGZsh{} F*cos at t\PYGZus{}i + dt/2 (for k2, k3)}
        \PYG{n}{f4}  \PYG{o}{=} \PYG{n}{cos\PYGZus{}full}\PYG{p}{[}\PYG{n}{i}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]}  \PYG{c+c1}{\PYGZsh{} F*cos at t\PYGZus{}i + dt   (for k4)}

        \PYG{c+c1}{\PYGZsh{} k1}
        \PYG{n}{k1x} \PYG{o}{=} \PYG{n}{DeltaT} \PYG{o}{*} \PYG{n}{vi}
        \PYG{n}{k1v} \PYG{o}{=} \PYG{n}{DeltaT} \PYG{o}{*} \PYG{n}{SpringForce}\PYG{p}{(}\PYG{n}{vi}\PYG{p}{,} \PYG{n}{xi}\PYG{p}{,} \PYG{n}{f1}\PYG{p}{,} \PYG{n}{gamma}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} k2}
        \PYG{n}{k2x} \PYG{o}{=} \PYG{n}{DeltaT} \PYG{o}{*} \PYG{p}{(}\PYG{n}{vi} \PYG{o}{+} \PYG{l+m+mf}{0.5}\PYG{o}{*}\PYG{n}{k1v}\PYG{p}{)}
        \PYG{n}{k2v} \PYG{o}{=} \PYG{n}{DeltaT} \PYG{o}{*} \PYG{n}{SpringForce}\PYG{p}{(}\PYG{n}{vi} \PYG{o}{+} \PYG{l+m+mf}{0.5}\PYG{o}{*}\PYG{n}{k1v}\PYG{p}{,} \PYG{n}{xi} \PYG{o}{+} \PYG{l+m+mf}{0.5}\PYG{o}{*}\PYG{n}{k1x}\PYG{p}{,} \PYG{n}{f24}\PYG{p}{,} \PYG{n}{gamma}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} k3}
