          \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{test: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{cae\PYGZus{}recon\PYGZus{}mse\PYGZus{}test}\PYG{l+s+si}{:}\PYG{l+s+s2}{.6f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}

