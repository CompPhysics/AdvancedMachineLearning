    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{maybe\PYGZus{}compile}\PYG{p}{(}\PYG{n}{model}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Apply torch.compile() only when USE\PYGZus{}COMPILE=True and PyTorch \PYGZgt{}= 2.0.}

\PYG{l+s+sd}{        torch.compile() spawns Triton/Inductor subprocesses on its first run.}
\PYG{l+s+sd}{        On Windows/macOS (\PYGZsq{}spawn\PYGZsq{} start method) this causes a RuntimeError}
\PYG{l+s+sd}{        (\PYGZdq{}bootstrapping phase\PYGZdq{}) unless called inside `if \PYGZus{}\PYGZus{}name\PYGZus{}\PYGZus{} == \PYGZsq{}\PYGZus{}\PYGZus{}main\PYGZus{}\PYGZus{}\PYGZsq{}:`.}
\PYG{l+s+sd}{        The USE\PYGZus{}COMPILE flag lets users enable compilation safely on Linux,}
\PYG{l+s+sd}{        where \PYGZsq{}fork\PYGZsq{} is the default start method and no re\PYGZhy{}import occurs.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k}{if} \PYG{n}{USE\PYGZus{}COMPILE} \PYG{o+ow}{and} \PYG{n+nb}{hasattr}\PYG{p}{(}\PYG{n}{torch}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}}\PYG{l+s+s1}{compile}\PYG{l+s+s1}{\PYGZsq{}}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{try}\PYG{p}{:}
