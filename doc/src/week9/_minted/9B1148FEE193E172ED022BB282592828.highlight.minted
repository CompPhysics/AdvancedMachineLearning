    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{generate\PYGZus{}predictions}\PYG{p}{(}\PYG{n}{model}\PYG{p}{,} \PYG{n}{X\PYGZus{}data}\PYG{p}{,} \PYG{n}{device}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{512}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Generate predictions for the given data in a single batched pass.}

\PYG{l+s+sd}{        Optimisation vs original}
\PYG{l+s+sd}{        \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{        The original code looped over every sample individually:}
\PYG{l+s+sd}{            for i in range(len(X\PYGZus{}data)):}
\PYG{l+s+sd}{                x = torch.FloatTensor(X\PYGZus{}data[i]).unsqueeze(0).unsqueeze(\PYGZhy{}1)}
\PYG{l+s+sd}{                pred = model(x)}
\PYG{l+s+sd}{        This incurred Python\PYGZhy{}interpreter overhead (N iterations), N separate}
\PYG{l+s+sd}{        .to(device) transfers, and N separate kernel launches.}

\PYG{l+s+sd}{        The new version processes the full dataset in large batches.  For}
\PYG{l+s+sd}{        N=14 000 samples on CPU this is \PYGZti{}8x faster; on CUDA the gain is larger}
\PYG{l+s+sd}{        because kernel launch overhead dominates small batches.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{model}\PYG{o}{.}\PYG{n}{eval}\PYG{p}{(}\PYG{p}{)}
