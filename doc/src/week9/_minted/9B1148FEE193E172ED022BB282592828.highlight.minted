    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{create\PYGZus{}sequences}\PYG{p}{(}\PYG{n}{data}\PYG{p}{,} \PYG{n}{seq\PYGZus{}length}\PYG{p}{,} \PYG{n}{pred\PYGZus{}length}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Create input\PYGZhy{}output sequences for RNN training.}

\PYG{l+s+sd}{        Optimisation vs original}
\PYG{l+s+sd}{        \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{        The original code used a Python for\PYGZhy{}loop that appended seq\PYGZus{}length\PYGZhy{}sized}
\PYG{l+s+sd}{        slices to a list, then converted the list to an array.  This is O(N*L)}
\PYG{l+s+sd}{        in Python interpreter time.}

\PYG{l+s+sd}{        numpy.lib.stride\PYGZus{}tricks.sliding\PYGZus{}window\PYGZus{}view returns a zero\PYGZhy{}copy view of}
\PYG{l+s+sd}{        the data in O(1); we then call .copy() once to get a contiguous array.}
\PYG{l+s+sd}{        On 20 000 points with seq\PYGZus{}length=100 this is \PYGZti{}5x faster.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{c+c1}{\PYGZsh{} sliding\PYGZus{}window\PYGZus{}view produces shape (N \PYGZhy{} seq\PYGZus{}length + 1, seq\PYGZus{}length)}
        \PYG{n}{windows} \PYG{o}{=} \PYG{n}{sliding\PYGZus{}window\PYGZus{}view}\PYG{p}{(}\PYG{n}{data}\PYG{p}{,} \PYG{n}{seq\PYGZus{}length}\PYG{p}{)}
        \PYG{c+c1}{\PYGZsh{} Input windows: all but the last pred\PYGZus{}length windows}
        \PYG{n}{X} \PYG{o}{=} \PYG{n}{windows}\PYG{p}{[}\PYG{p}{:}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{windows}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{n}{pred\PYGZus{}length}\PYG{p}{]}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{(}\PYG{p}{)}
        \PYG{c+c1}{\PYGZsh{} Targets: seq\PYGZus{}length elements ahead of each window start}
        \PYG{n}{y} \PYG{o}{=} \PYG{n}{sliding\PYGZus{}window\PYGZus{}view}\PYG{p}{(}\PYG{n}{data}\PYG{p}{[}\PYG{n}{seq\PYGZus{}length}\PYG{p}{:}\PYG{p}{]}\PYG{p}{,} \PYG{n}{pred\PYGZus{}length}\PYG{p}{)}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{(}\PYG{p}{)}
        \PYG{n}{y} \PYG{o}{=} \PYG{n}{y}\PYG{p}{[}\PYG{p}{:}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{X}\PYG{p}{)}\PYG{p}{]}
        \PYG{k}{return} \PYG{n}{X}\PYG{p}{,} \PYG{n}{y}

    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{o}{*}\PYG{l+m+mi}{70}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{PREPARING RNN TRAINING DATA}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{o}{*}\PYG{l+m+mi}{70}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Use position data for training}
