                \PYG{n}{batch} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{FloatTensor}\PYG{p}{(}\PYG{n}{X\PYGZus{}data}\PYG{p}{[}\PYG{n}{i}\PYG{p}{:}\PYG{n}{i} \PYG{o}{+} \PYG{n}{batch\PYGZus{}size}\PYG{p}{]}\PYG{p}{)}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}
                    \PYG{n}{device}\PYG{p}{,} \PYG{n}{non\PYGZus{}blocking}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
