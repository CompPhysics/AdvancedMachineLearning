            \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{X\PYGZus{}data}\PYG{p}{)}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{p}{)}\PYG{p}{:}
                \PYG{n}{batch}  \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{FloatTensor}\PYG{p}{(}\PYG{n}{X\PYGZus{}data}\PYG{p}{[}\PYG{n}{i}\PYG{p}{:}\PYG{n}{i} \PYG{o}{+} \PYG{n}{batch\PYGZus{}size}\PYG{p}{]}\PYG{p}{)}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}
                    \PYG{n}{device}\PYG{p}{,} \PYG{n}{non\PYGZus{}blocking}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
                \PYG{n}{z\PYGZus{}t}    \PYG{o}{=} \PYG{n}{cae}\PYG{o}{.}\PYG{n}{encode}\PYG{p}{(}\PYG{n}{batch}\PYG{p}{)}
                \PYG{n}{z\PYGZus{}next} \PYG{o}{=} \PYG{n}{lat\PYGZus{}pred}\PYG{p}{(}\PYG{n}{z\PYGZus{}t}\PYG{p}{)}
                \PYG{n}{x\PYGZus{}next} \PYG{o}{=} \PYG{n}{cae}\PYG{o}{.}\PYG{n}{decode}\PYG{p}{(}\PYG{n}{z\PYGZus{}next}\PYG{p}{)}
                \PYG{n}{preds}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{x\PYGZus{}next}\PYG{p}{[}\PYG{p}{:}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{o}{.}\PYG{n}{cpu}\PYG{p}{(}\PYG{p}{)}\PYG{o}{.}\PYG{n}{numpy}\PYG{p}{(}\PYG{p}{)}\PYG{p}{)}
        \PYG{k}{return} \PYG{n}{np}\PYG{o}{.}\PYG{n}{concatenate}\PYG{p}{(}\PYG{n}{preds}\PYG{p}{,} \PYG{n}{axis}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{)}


