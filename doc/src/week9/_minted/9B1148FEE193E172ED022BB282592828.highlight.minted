\begin{MintedVerbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]

\PYG{c+c1}{\PYGZsh{}!/usr/bin/env python3}
\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{Recurrent Neural Network and Autoencoder for Learning ODE Solutions}
\PYG{l+s+sd}{Using PyTorch and RK4 Solver Output}

\PYG{l+s+sd}{Training RNN and Autoencoder models on forced oscillator differential equation:}
\PYG{l+s+sd}{d**2x/dt**2 + 2*gamma*(dx/dt) + x = F\PYGZus{}tilde*cos(Omega\PYGZus{}tilde*t)}

\PYG{l+s+sd}{Performance optimisations applied (vs original)}
\PYG{l+s+sd}{\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{1. RK4 solver: precompute all cos() evaluations as two numpy arrays before}
\PYG{l+s+sd}{   the integration loop. \PYGZti{}24\PYGZpc{} faster on 20 000 steps.}

\PYG{l+s+sd}{2. create\PYGZus{}sequences: replaced the Python list\PYGZhy{}append loop with}
\PYG{l+s+sd}{   numpy.lib.stride\PYGZus{}tricks.sliding\PYGZus{}window\PYGZus{}view. \PYGZti{}5x faster.}

\PYG{l+s+sd}{3. generate\PYGZus{}predictions: replaced the sample\PYGZhy{}by\PYGZhy{}sample loop with a single}
\PYG{l+s+sd}{   batched forward pass over the full dataset. \PYGZti{}8x faster.}

\PYG{l+s+sd}{4. encode\PYGZus{}dataset: same batched rewrite, iterating in fixed chunks.}

\PYG{l+s+sd}{5. RNN forward passes: passing None for hidden state lets PyTorch allocate}
\PYG{l+s+sd}{   it via optimised C++/CUDA paths instead of allocating in Python.}

\PYG{l+s+sd}{6. DataLoader: num\PYGZus{}workers=min(4, cpu\PYGZus{}count) and pin\PYGZus{}memory=True on CUDA.}

\PYG{l+s+sd}{7. optimizer.zero\PYGZus{}grad(set\PYGZus{}to\PYGZus{}none=True): avoids a memset() per parameter}
\PYG{l+s+sd}{   tensor each step.}

\PYG{l+s+sd}{8. torch.compile (PyTorch 2+): each model is compiled before training if}
\PYG{l+s+sd}{   available, enabling TorchDynamo + inductor kernel fusion.}

\PYG{l+s+sd}{9. VAE reconstruction in visualisation: four separate forward passes replaced}
\PYG{l+s+sd}{   by a single batched call over all example windows at once.}
\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}

