    \PYG{c+c1}{\PYGZsh{} ============================================================================}
    \PYG{c+c1}{\PYGZsh{} PART IX: AUTOENCODER MODELS}
    \PYG{c+c1}{\PYGZsh{} ============================================================================}
    \PYG{c+c1}{\PYGZsh{}}
    \PYG{c+c1}{\PYGZsh{} Two autoencoder variants are implemented, both operating on the same}
    \PYG{c+c1}{\PYGZsh{} sliding\PYGZhy{}window sequences (shape: [batch, seq\PYGZus{}length=100]) that were used}
    \PYG{c+c1}{\PYGZsh{} for the RNNs.}
    \PYG{c+c1}{\PYGZsh{}}
    \PYG{c+c1}{\PYGZsh{} Architecture overview}
    \PYG{c+c1}{\PYGZsh{} \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
    \PYG{c+c1}{\PYGZsh{} ConvAutoencoder (CAE)}
    \PYG{c+c1}{\PYGZsh{}   Encoder: 1\PYGZhy{}D convolutions  →  bottleneck of size `latent\PYGZus{}dim`}
    \PYG{c+c1}{\PYGZsh{}   Decoder: transposed 1\PYGZhy{}D convolutions  →  reconstructed sequence}
    \PYG{c+c1}{\PYGZsh{}   Loss: MSELoss on the full reconstructed window}
    \PYG{c+c1}{\PYGZsh{}}
    \PYG{c+c1}{\PYGZsh{} VariationalAutoencoder (VAE)}
    \PYG{c+c1}{\PYGZsh{}   Encoder: same convolutional stack  →  (mu, log\PYGZus{}var) each of size `latent\PYGZus{}dim`}
    \PYG{c+c1}{\PYGZsh{}   Reparametrisation trick: z = mu + eps * exp(0.5 * log\PYGZus{}var)}
    \PYG{c+c1}{\PYGZsh{}   Decoder: same transposed stack}
    \PYG{c+c1}{\PYGZsh{}   Loss: reconstruction MSE + KL divergence  β * KL(q||N(0,I))}
    \PYG{c+c1}{\PYGZsh{}}
    \PYG{c+c1}{\PYGZsh{} LatentPredictor}
    \PYG{c+c1}{\PYGZsh{}   After training the CAE, the encoder maps each training window to a}
    \PYG{c+c1}{\PYGZsh{}   latent vector.  A small MLP is then trained to predict the *next*}
    \PYG{c+c1}{\PYGZsh{}   latent vector from the current one.  At inference time:}
    \PYG{c+c1}{\PYGZsh{}       encode(window) → predict\PYGZus{}next\PYGZus{}latent → decode → scalar prediction}
    \PYG{c+c1}{\PYGZsh{}   This connects the compression view to the time\PYGZhy{}series prediction task}
    \PYG{c+c1}{\PYGZsh{}   performed by the RNNs.}

    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{o}{*}\PYG{l+m+mi}{70}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{PART IX: AUTOENCODER MODELS}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{o}{*}\PYG{l+m+mi}{70}\PYG{p}{)}


    \PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{ConvAutoencoder}\PYG{p}{(}\PYG{n}{nn}\PYG{o}{.}\PYG{n}{Module}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        1\PYGZhy{}D Convolutional Autoencoder for time\PYGZhy{}series windows.}

\PYG{l+s+sd}{        Encoder}
\PYG{l+s+sd}{        \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{        Conv1d(1  → 16, k=5, s=2, p=2)  + ReLU   →  seq/2}
\PYG{l+s+sd}{        Conv1d(16 → 32, k=5, s=2, p=2)  + ReLU   →  seq/4}
\PYG{l+s+sd}{        Conv1d(32 → 64, k=3, s=2, p=1)  + ReLU   →  seq/8}
\PYG{l+s+sd}{        Flatten  →  Linear(64 * seq\PYGZus{}enc, latent\PYGZus{}dim)}

\PYG{l+s+sd}{        Decoder}
\PYG{l+s+sd}{        \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{l+s+sd}{        Linear(latent\PYGZus{}dim, 64 * seq\PYGZus{}enc)}
\PYG{l+s+sd}{        ConvTranspose1d(64 → 32, k=3, s=2, p=1, out\PYGZus{}p=1)  + ReLU}
\PYG{l+s+sd}{        ConvTranspose1d(32 → 16, k=5, s=2, p=2, out\PYGZus{}p=1)  + ReLU}
\PYG{l+s+sd}{        ConvTranspose1d(16 →  1, k=5, s=2, p=2, out\PYGZus{}p=1)}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{seq\PYGZus{}length}\PYG{o}{=}\PYG{l+m+mi}{100}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{o}{=}\PYG{l+m+mi}{16}\PYG{p}{)}\PYG{p}{:}
            \PYG{n+nb}{super}\PYG{p}{(}\PYG{n}{ConvAutoencoder}\PYG{p}{,} \PYG{n+nb+bp}{self}\PYG{p}{)}\PYG{o}{.}\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}length} \PYG{o}{=} \PYG{n}{seq\PYGZus{}length}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{latent\PYGZus{}dim} \PYG{o}{=} \PYG{n}{latent\PYGZus{}dim}

            \PYG{c+c1}{\PYGZsh{} Encoder strides: 2, 2, 2  →  seq\PYGZus{}length / 8 (rounded)}
            \PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{math}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc} \PYG{o}{=} \PYG{n}{math}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{(}\PYG{n}{math}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{(}\PYG{n}{math}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{(}\PYG{n}{seq\PYGZus{}length} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)}

            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encoder\PYGZus{}conv} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{l+m+mi}{16}\PYG{p}{,} \PYG{l+m+mi}{32}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{l+m+mi}{32}\PYG{p}{,} \PYG{l+m+mi}{64}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{3}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
            \PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encoder\PYGZus{}fc} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{l+m+mi}{64} \PYG{o}{*} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{p}{)}

            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}fc} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{latent\PYGZus{}dim}\PYG{p}{,} \PYG{l+m+mi}{64} \PYG{o}{*} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc}\PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}conv} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ConvTranspose1d}\PYG{p}{(}\PYG{l+m+mi}{64}\PYG{p}{,} \PYG{l+m+mi}{32}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{3}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{output\PYGZus{}padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ConvTranspose1d}\PYG{p}{(}\PYG{l+m+mi}{32}\PYG{p}{,} \PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{output\PYGZus{}padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ConvTranspose1d}\PYG{p}{(}\PYG{l+m+mi}{16}\PYG{p}{,}  \PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{output\PYGZus{}padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
            \PYG{p}{)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{encode}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{)}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} x: (B, seq\PYGZus{}length)  →  add channel dim  →  (B, 1, seq\PYGZus{}length)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{o}{.}\PYG{n}{unsqueeze}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encoder\PYGZus{}conv}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}          \PYG{c+c1}{\PYGZsh{} (B, 64, seq\PYGZus{}enc)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{o}{.}\PYG{n}{view}\PYG{p}{(}\PYG{n}{x}\PYG{o}{.}\PYG{n}{size}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{)}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{)}        \PYG{c+c1}{\PYGZsh{} (B, 64*seq\PYGZus{}enc)}
            \PYG{k}{return} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encoder\PYGZus{}fc}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}         \PYG{c+c1}{\PYGZsh{} (B, latent\PYGZus{}dim)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{decode}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{z}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{x} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}fc}\PYG{p}{(}\PYG{n}{z}\PYG{p}{)}            \PYG{c+c1}{\PYGZsh{} (B, 64*seq\PYGZus{}enc)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{o}{.}\PYG{n}{view}\PYG{p}{(}\PYG{n}{x}\PYG{o}{.}\PYG{n}{size}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{)}\PYG{p}{,} \PYG{l+m+mi}{64}\PYG{p}{,} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}conv}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}          \PYG{c+c1}{\PYGZsh{} (B, 1, seq\PYGZus{}length\PYGZsq{})}
            \PYG{c+c1}{\PYGZsh{} Trim or pad to exactly seq\PYGZus{}length}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{p}{[}\PYG{p}{:}\PYG{p}{,} \PYG{l+m+mi}{0}\PYG{p}{,} \PYG{p}{:}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}length}\PYG{p}{]}     \PYG{c+c1}{\PYGZsh{} (B, seq\PYGZus{}length)}
            \PYG{k}{return} \PYG{n}{x}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{z} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encode}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}
            \PYG{k}{return} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decode}\PYG{p}{(}\PYG{n}{z}\PYG{p}{)}\PYG{p}{,} \PYG{n}{z}


    \PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{VariationalAutoencoder}\PYG{p}{(}\PYG{n}{nn}\PYG{o}{.}\PYG{n}{Module}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Variational Autoencoder with convolutional encoder/decoder.}

\PYG{l+s+sd}{        Identical convolutional stack as ConvAutoencoder, but the encoder}
\PYG{l+s+sd}{        outputs (mu, log\PYGZus{}var) and z is drawn via the reparametrisation trick.}

\PYG{l+s+sd}{        Loss = reconstruction\PYGZus{}MSE + beta * KL\PYGZus{}divergence}
\PYG{l+s+sd}{        KL   = \PYGZhy{}0.5 * sum(1 + log\PYGZus{}var \PYGZhy{} mu² \PYGZhy{} exp(log\PYGZus{}var))}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{seq\PYGZus{}length}\PYG{o}{=}\PYG{l+m+mi}{100}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{o}{=}\PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{beta}\PYG{o}{=}\PYG{l+m+mf}{1.0}\PYG{p}{)}\PYG{p}{:}
            \PYG{n+nb}{super}\PYG{p}{(}\PYG{n}{VariationalAutoencoder}\PYG{p}{,} \PYG{n+nb+bp}{self}\PYG{p}{)}\PYG{o}{.}\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}length} \PYG{o}{=} \PYG{n}{seq\PYGZus{}length}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{latent\PYGZus{}dim} \PYG{o}{=} \PYG{n}{latent\PYGZus{}dim}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{beta} \PYG{o}{=} \PYG{n}{beta}

            \PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{math}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc} \PYG{o}{=} \PYG{n}{math}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{(}\PYG{n}{math}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{(}\PYG{n}{math}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{(}\PYG{n}{seq\PYGZus{}length} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)}

            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encoder\PYGZus{}conv} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{l+m+mi}{16}\PYG{p}{,} \PYG{l+m+mi}{32}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{l+m+mi}{32}\PYG{p}{,} \PYG{l+m+mi}{64}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{3}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
            \PYG{p}{)}
            \PYG{n}{flat\PYGZus{}size} \PYG{o}{=} \PYG{l+m+mi}{64} \PYG{o}{*} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc\PYGZus{}mu}      \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{flat\PYGZus{}size}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc\PYGZus{}log\PYGZus{}var} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{flat\PYGZus{}size}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{p}{)}

            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}fc} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{latent\PYGZus{}dim}\PYG{p}{,} \PYG{n}{flat\PYGZus{}size}\PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}conv} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ConvTranspose1d}\PYG{p}{(}\PYG{l+m+mi}{64}\PYG{p}{,} \PYG{l+m+mi}{32}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{3}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{output\PYGZus{}padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ConvTranspose1d}\PYG{p}{(}\PYG{l+m+mi}{32}\PYG{p}{,} \PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{output\PYGZus{}padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ConvTranspose1d}\PYG{p}{(}\PYG{l+m+mi}{16}\PYG{p}{,}  \PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{,} \PYG{n}{stride}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{output\PYGZus{}padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
            \PYG{p}{)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{encode}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{o}{.}\PYG{n}{unsqueeze}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encoder\PYGZus{}conv}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{o}{.}\PYG{n}{view}\PYG{p}{(}\PYG{n}{x}\PYG{o}{.}\PYG{n}{size}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{)}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{)}
            \PYG{k}{return} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc\PYGZus{}mu}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}\PYG{p}{,} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{fc\PYGZus{}log\PYGZus{}var}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{reparametrise}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{mu}\PYG{p}{,} \PYG{n}{log\PYGZus{}var}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{if} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{training}\PYG{p}{:}
                \PYG{n}{std} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{exp}\PYG{p}{(}\PYG{l+m+mf}{0.5} \PYG{o}{*} \PYG{n}{log\PYGZus{}var}\PYG{p}{)}
                \PYG{n}{eps} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{randn\PYGZus{}like}\PYG{p}{(}\PYG{n}{std}\PYG{p}{)}
                \PYG{k}{return} \PYG{n}{mu} \PYG{o}{+} \PYG{n}{eps} \PYG{o}{*} \PYG{n}{std}
            \PYG{k}{return} \PYG{n}{mu}  \PYG{c+c1}{\PYGZsh{} deterministic at inference}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{decode}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{z}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{x} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}fc}\PYG{p}{(}\PYG{n}{z}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{o}{.}\PYG{n}{view}\PYG{p}{(}\PYG{n}{x}\PYG{o}{.}\PYG{n}{size}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{)}\PYG{p}{,} \PYG{l+m+mi}{64}\PYG{p}{,} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}enc}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decoder\PYGZus{}conv}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}
            \PYG{n}{x} \PYG{o}{=} \PYG{n}{x}\PYG{p}{[}\PYG{p}{:}\PYG{p}{,} \PYG{l+m+mi}{0}\PYG{p}{,} \PYG{p}{:}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{seq\PYGZus{}length}\PYG{p}{]}
            \PYG{k}{return} \PYG{n}{x}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{mu}\PYG{p}{,} \PYG{n}{log\PYGZus{}var} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encode}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}
            \PYG{n}{z} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{reparametrise}\PYG{p}{(}\PYG{n}{mu}\PYG{p}{,} \PYG{n}{log\PYGZus{}var}\PYG{p}{)}
            \PYG{n}{recon} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decode}\PYG{p}{(}\PYG{n}{z}\PYG{p}{)}
            \PYG{k}{return} \PYG{n}{recon}\PYG{p}{,} \PYG{n}{mu}\PYG{p}{,} \PYG{n}{log\PYGZus{}var}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{vae\PYGZus{}loss}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{recon}\PYG{p}{,} \PYG{n}{x}\PYG{p}{,} \PYG{n}{mu}\PYG{p}{,} \PYG{n}{log\PYGZus{}var}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{recon\PYGZus{}loss} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{functional}\PYG{o}{.}\PYG{n}{mse\PYGZus{}loss}\PYG{p}{(}\PYG{n}{recon}\PYG{p}{,} \PYG{n}{x}\PYG{p}{,} \PYG{n}{reduction}\PYG{o}{=}\PYG{l+s+s1}{\PYGZsq{}}\PYG{l+s+s1}{mean}\PYG{l+s+s1}{\PYGZsq{}}\PYG{p}{)}
            \PYG{n}{kl} \PYG{o}{=} \PYG{o}{\PYGZhy{}}\PYG{l+m+mf}{0.5} \PYG{o}{*} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{l+m+mi}{1} \PYG{o}{+} \PYG{n}{log\PYGZus{}var} \PYG{o}{\PYGZhy{}} \PYG{n}{mu}\PYG{o}{.}\PYG{n}{pow}\PYG{p}{(}\PYG{l+m+mi}{2}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{n}{log\PYGZus{}var}\PYG{o}{.}\PYG{n}{exp}\PYG{p}{(}\PYG{p}{)}\PYG{p}{)}
            \PYG{k}{return} \PYG{n}{recon\PYGZus{}loss} \PYG{o}{+} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{beta} \PYG{o}{*} \PYG{n}{kl}\PYG{p}{,} \PYG{n}{recon\PYGZus{}loss}\PYG{p}{,} \PYG{n}{kl}


    \PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{LatentPredictor}\PYG{p}{(}\PYG{n}{nn}\PYG{o}{.}\PYG{n}{Module}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        MLP that predicts the next latent vector from the current one.}

\PYG{l+s+sd}{        Used together with a pre\PYGZhy{}trained ConvAutoencoder encoder/decoder:}
\PYG{l+s+sd}{            encode(window\PYGZus{}t)  →  z\PYGZus{}t}
\PYG{l+s+sd}{            predict(z\PYGZus{}t)      →  z\PYGZus{}\PYGZob{}t+1\PYGZcb{}  (predicted)}
\PYG{l+s+sd}{            decode(z\PYGZus{}\PYGZob{}t+1\PYGZcb{})   →  x\PYGZus{}\PYGZob{}t+1\PYGZcb{} sequence (take last element as scalar pred)}

\PYG{l+s+sd}{        Architecture: Linear(latent→128) + ReLU + Linear(128→128) + ReLU + Linear(128→latent)}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{o}{=}\PYG{l+m+mi}{16}\PYG{p}{)}\PYG{p}{:}
            \PYG{n+nb}{super}\PYG{p}{(}\PYG{n}{LatentPredictor}\PYG{p}{,} \PYG{n+nb+bp}{self}\PYG{p}{)}\PYG{o}{.}\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{p}{)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{net} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{latent\PYGZus{}dim}\PYG{p}{,} \PYG{l+m+mi}{128}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{l+m+mi}{128}\PYG{p}{,} \PYG{l+m+mi}{128}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{l+m+mi}{128}\PYG{p}{,} \PYG{n}{latent\PYGZus{}dim}\PYG{p}{)}\PYG{p}{,}
            \PYG{p}{)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{z}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{return} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{net}\PYG{p}{(}\PYG{n}{z}\PYG{p}{)}


    \PYG{c+c1}{\PYGZsh{} ============================================================================}
    \PYG{c+c1}{\PYGZsh{} PART X: AUTOENCODER DATASETS AND TRAINING FUNCTIONS}
    \PYG{c+c1}{\PYGZsh{} ============================================================================}

    \PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{AEDataset}\PYG{p}{(}\PYG{n}{Dataset}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Dataset for autoencoder training.}
\PYG{l+s+sd}{        Returns windows of shape (seq\PYGZus{}length,) — the AE reconstructs the whole window.}
\PYG{l+s+sd}{        The RNN datasets returned (window, next\PYGZus{}value); the AE dataset returns only the}
\PYG{l+s+sd}{        window itself (no target needed for reconstruction).  For the latent predictor}
\PYG{l+s+sd}{        we also build a paired dataset of (z\PYGZus{}t, z\PYGZus{}\PYGZob{}t+1\PYGZcb{}).}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{X}\PYG{p}{)}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} X shape: (N, seq\PYGZus{}length)}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{X} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{FloatTensor}\PYG{p}{(}\PYG{n}{X}\PYG{p}{)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}len\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{return} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{X}\PYG{p}{)}

        \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}getitem\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{idx}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{return} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{X}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{]}


    \PYG{c+c1}{\PYGZsh{} Build AE\PYGZhy{}specific dataloaders (no target; larger batches are fine for AE)}
    \PYG{n}{ae\PYGZus{}batch\PYGZus{}size} \PYG{o}{=} \PYG{l+m+mi}{128}
    \PYG{n}{ae\PYGZus{}train\PYGZus{}loader} \PYG{o}{=} \PYG{n}{DataLoader}\PYG{p}{(}
        \PYG{n}{AEDataset}\PYG{p}{(}\PYG{n}{X\PYGZus{}train}\PYG{p}{)}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{n}{ae\PYGZus{}batch\PYGZus{}size}\PYG{p}{,} \PYG{n}{shuffle}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{,}
        \PYG{n}{num\PYGZus{}workers}\PYG{o}{=}\PYG{n}{\PYGZus{}NUM\PYGZus{}WORKERS}\PYG{p}{,} \PYG{n}{pin\PYGZus{}memory}\PYG{o}{=}\PYG{n}{\PYGZus{}PIN\PYGZus{}MEMORY}
    \PYG{p}{)}
    \PYG{n}{ae\PYGZus{}test\PYGZus{}loader} \PYG{o}{=} \PYG{n}{DataLoader}\PYG{p}{(}
        \PYG{n}{AEDataset}\PYG{p}{(}\PYG{n}{X\PYGZus{}test}\PYG{p}{)}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{n}{ae\PYGZus{}batch\PYGZus{}size}\PYG{p}{,} \PYG{n}{shuffle}\PYG{o}{=}\PYG{k+kc}{False}\PYG{p}{,}
        \PYG{n}{num\PYGZus{}workers}\PYG{o}{=}\PYG{n}{\PYGZus{}NUM\PYGZus{}WORKERS}\PYG{p}{,} \PYG{n}{pin\PYGZus{}memory}\PYG{o}{=}\PYG{n}{\PYGZus{}PIN\PYGZus{}MEMORY}
    \PYG{p}{)}

    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{Autoencoder DataLoaders:}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{  Input window shape : (batch, }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{seq\PYGZus{}length}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{)}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{  Batch size         : }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{ae\PYGZus{}batch\PYGZus{}size}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{  Train batches      : }\PYG{l+s+si}{\PYGZob{}}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{ae\PYGZus{}train\PYGZus{}loader}\PYG{p}{)}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{  Test batches       : }\PYG{l+s+si}{\PYGZob{}}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{ae\PYGZus{}test\PYGZus{}loader}\PYG{p}{)}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}


    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{train\PYGZus{}cae\PYGZus{}epoch}\PYG{p}{(}\PYG{n}{model}\PYG{p}{,} \PYG{n}{loader}\PYG{p}{,} \PYG{n}{optimizer}\PYG{p}{,} \PYG{n}{device}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}One training epoch for the ConvAutoencoder.\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{model}\PYG{o}{.}\PYG{n}{train}\PYG{p}{(}\PYG{p}{)}
        \PYG{n}{total} \PYG{o}{=} \PYG{l+m+mf}{0.0}
        \PYG{n}{criterion} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{MSELoss}\PYG{p}{(}\PYG{p}{)}
        \PYG{k}{for} \PYG{n}{batch} \PYG{o+ow}{in} \PYG{n}{loader}\PYG{p}{:}
            \PYG{n}{batch} \PYG{o}{=} \PYG{n}{batch}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{,} \PYG{n}{non\PYGZus{}blocking}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
            \PYG{n}{recon}\PYG{p}{,} \PYG{n}{\PYGZus{}} \PYG{o}{=} \PYG{n}{model}\PYG{p}{(}\PYG{n}{batch}\PYG{p}{)}
            \PYG{n}{loss} \PYG{o}{=} \PYG{n}{criterion}\PYG{p}{(}\PYG{n}{recon}\PYG{p}{,} \PYG{n}{batch}\PYG{p}{)}
            \PYG{n}{optimizer}\PYG{o}{.}\PYG{n}{zero\PYGZus{}grad}\PYG{p}{(}\PYG{n}{set\PYGZus{}to\PYGZus{}none}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
            \PYG{n}{loss}\PYG{o}{.}\PYG{n}{backward}\PYG{p}{(}\PYG{p}{)}
            \PYG{n}{optimizer}\PYG{o}{.}\PYG{n}{step}\PYG{p}{(}\PYG{p}{)}
            \PYG{n}{total} \PYG{o}{+}\PYG{o}{=} \PYG{n}{loss}\PYG{o}{.}\PYG{n}{item}\PYG{p}{(}\PYG{p}{)}
