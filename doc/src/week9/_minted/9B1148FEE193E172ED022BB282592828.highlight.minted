    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{o}{*}\PYG{l+m+mi}{70}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{AUTOENCODER PREDICTIONS AND METRICS}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{o}{*}\PYG{l+m+mi}{70}\PYG{p}{)}


    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{cae\PYGZus{}reconstruct}\PYG{p}{(}\PYG{n}{cae}\PYG{p}{,} \PYG{n}{X\PYGZus{}data}\PYG{p}{,} \PYG{n}{device}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{512}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Reconstruct each window and return array of reconstructed sequences.\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{cae}\PYG{o}{.}\PYG{n}{eval}\PYG{p}{(}\PYG{p}{)}
        \PYG{n}{recons} \PYG{o}{=} \PYG{p}{[}\PYG{p}{]}
        \PYG{k}{with} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{no\PYGZus{}grad}\PYG{p}{(}\PYG{p}{)}\PYG{p}{:}
            \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{X\PYGZus{}data}\PYG{p}{)}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{p}{)}\PYG{p}{:}
                \PYG{n}{batch} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{FloatTensor}\PYG{p}{(}\PYG{n}{X\PYGZus{}data}\PYG{p}{[}\PYG{n}{i}\PYG{p}{:}\PYG{n}{i} \PYG{o}{+} \PYG{n}{batch\PYGZus{}size}\PYG{p}{]}\PYG{p}{)}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}
                    \PYG{n}{device}\PYG{p}{,} \PYG{n}{non\PYGZus{}blocking}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
                \PYG{n}{recon}\PYG{p}{,} \PYG{n}{\PYGZus{}} \PYG{o}{=} \PYG{n}{cae}\PYG{p}{(}\PYG{n}{batch}\PYG{p}{)}
                \PYG{n}{recons}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{recon}\PYG{o}{.}\PYG{n}{cpu}\PYG{p}{(}\PYG{p}{)}\PYG{o}{.}\PYG{n}{numpy}\PYG{p}{(}\PYG{p}{)}\PYG{p}{)}
        \PYG{k}{return} \PYG{n}{np}\PYG{o}{.}\PYG{n}{concatenate}\PYG{p}{(}\PYG{n}{recons}\PYG{p}{,} \PYG{n}{axis}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{)}   \PYG{c+c1}{\PYGZsh{} (N, seq\PYGZus{}length)}


    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{latent\PYGZus{}predictor\PYGZus{}predict}\PYG{p}{(}\PYG{n}{cae}\PYG{p}{,} \PYG{n}{lat\PYGZus{}pred}\PYG{p}{,} \PYG{n}{X\PYGZus{}data}\PYG{p}{,} \PYG{n}{device}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{512}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        For each input window:}
\PYG{l+s+sd}{          1. encode to z\PYGZus{}t}
\PYG{l+s+sd}{          2. predict z\PYGZus{}\PYGZob{}t+1\PYGZcb{} via MLP}
