\PYG{l+s+sd}{        non\PYGZus{}blocking=True overlaps the CPU→device transfer with computation.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{cae}\PYG{o}{.}\PYG{n}{eval}\PYG{p}{(}\PYG{p}{)}
