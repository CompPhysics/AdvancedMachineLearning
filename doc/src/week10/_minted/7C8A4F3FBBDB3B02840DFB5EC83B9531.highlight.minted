\PYG{c+c1}{\PYGZsh{} Symmetric recurrent autoencoder for MNIST rows (28 time\PYGZhy{}steps of 28 features).}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} Encoder: LSTM(100, return\PYGZus{}seq=True) \PYGZhy{}\PYGZgt{} LSTM(30)}
\PYG{c+c1}{\PYGZsh{}          (sequence of 28 rows \PYGZhy{}\PYGZgt{} 30\PYGZhy{}dim code)}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} Decoder: exact mirror in reverse order}
\PYG{c+c1}{\PYGZsh{}   RepeatVector(28)                        broadcast code to 28 steps}
\PYG{c+c1}{\PYGZsh{}   LSTM(30,  return\PYGZus{}seq=True)              mirror of encoder LSTM(30) [1]}
\PYG{c+c1}{\PYGZsh{}   LSTM(100, return\PYGZus{}seq=True)              mirror of encoder LSTM(100)}
\PYG{c+c1}{\PYGZsh{}   TimeDistributed(Dense(28, sigmoid))     reconstruct each row}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} [1] The innermost decoder LSTM uses 30 units (matching the bottleneck size)}
\PYG{c+c1}{\PYGZsh{}     before expanding back to 100 units, giving a true structural mirror.}

\PYG{n}{recurrent\PYGZus{}encoder} \PYG{o}{=} \PYG{n}{keras}\PYG{o}{.}\PYG{n}{models}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}\PYG{p}{[}
    \PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{LSTM}\PYG{p}{(}\PYG{l+m+mi}{100}\PYG{p}{,} \PYG{n}{return\PYGZus{}sequences}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{,} \PYG{n}{input\PYGZus{}shape}\PYG{o}{=}\PYG{p}{[}\PYG{l+m+mi}{28}\PYG{p}{,} \PYG{l+m+mi}{28}\PYG{p}{]}\PYG{p}{)}\PYG{p}{,}
    \PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{LSTM}\PYG{p}{(}\PYG{l+m+mi}{30}\PYG{p}{)}\PYG{p}{,}
\PYG{p}{]}\PYG{p}{,} \PYG{n}{name}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{recurrent\PYGZus{}encoder}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}

\PYG{n}{recurrent\PYGZus{}decoder} \PYG{o}{=} \PYG{n}{keras}\PYG{o}{.}\PYG{n}{models}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}\PYG{p}{[}
    \PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{RepeatVector}\PYG{p}{(}\PYG{l+m+mi}{28}\PYG{p}{,} \PYG{n}{input\PYGZus{}shape}\PYG{o}{=}\PYG{p}{[}\PYG{l+m+mi}{30}\PYG{p}{]}\PYG{p}{)}\PYG{p}{,}
    \PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{LSTM}\PYG{p}{(}\PYG{l+m+mi}{30}\PYG{p}{,}  \PYG{n}{return\PYGZus{}sequences}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}\PYG{p}{,}   \PYG{c+c1}{\PYGZsh{} mirror of inner encoder LSTM}
    \PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{LSTM}\PYG{p}{(}\PYG{l+m+mi}{100}\PYG{p}{,} \PYG{n}{return\PYGZus{}sequences}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}\PYG{p}{,}   \PYG{c+c1}{\PYGZsh{} mirror of outer encoder LSTM}
    \PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{TimeDistributed}\PYG{p}{(}\PYG{n}{keras}\PYG{o}{.}\PYG{n}{layers}\PYG{o}{.}\PYG{n}{Dense}\PYG{p}{(}\PYG{l+m+mi}{28}\PYG{p}{,} \PYG{n}{activation}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{sigmoid}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}\PYG{p}{)}\PYG{p}{,}
\PYG{p}{]}\PYG{p}{,} \PYG{n}{name}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{recurrent\PYGZus{}decoder}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}

\PYG{n}{recurrent\PYGZus{}ae} \PYG{o}{=} \PYG{n}{keras}\PYG{o}{.}\PYG{n}{models}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}\PYG{p}{[}\PYG{n}{recurrent\PYGZus{}encoder}\PYG{p}{,} \PYG{n}{recurrent\PYGZus{}decoder}\PYG{p}{]}\PYG{p}{,}
                                        \PYG{n}{name}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{recurrent\PYGZus{}ae}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
\PYG{n}{recurrent\PYGZus{}ae}\PYG{o}{.}\PYG{n}{compile}\PYG{p}{(}\PYG{n}{loss}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{binary\PYGZus{}crossentropy}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,}
