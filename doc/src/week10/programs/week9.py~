class LatentDataset(Dataset):
    def __init__(self, Z):
        Z = torch.FloatTensor(Z)
        self.src = Z[:-1]; self.tgt = Z[1:]
    def __len__(self): return len(self.src)
    def __getitem__(self, i): return self.src[i], self.tgt[i]

