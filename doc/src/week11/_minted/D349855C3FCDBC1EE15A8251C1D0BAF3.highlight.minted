        \PYG{k}{return} \PYG{n}{prob\PYGZus{}v}

\PYG{c+c1}{\PYGZsh{} Generate synthetic binary data}
\PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{seed}\PYG{p}{(}\PYG{l+m+mi}{42}\PYG{p}{)}
