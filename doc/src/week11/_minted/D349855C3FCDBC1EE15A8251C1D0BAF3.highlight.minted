        \PYG{n}{pos\PYGZus{}associations} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{outer}\PYG{p}{(}\PYG{n}{v0}\PYG{p}{,} \PYG{n}{prob\PYGZus{}h0}\PYG{p}{)}
