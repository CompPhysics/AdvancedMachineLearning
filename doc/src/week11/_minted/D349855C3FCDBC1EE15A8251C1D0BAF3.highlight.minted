    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{sample\PYGZus{}hidden}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{v}\PYG{p}{)}\PYG{p}{:}
        \PYG{c+c1}{\PYGZsh{} Sample hidden units given visible units.}
