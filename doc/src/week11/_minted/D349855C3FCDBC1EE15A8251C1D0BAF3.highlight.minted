    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{contrastive\PYGZus{}divergence}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{v0}\PYG{p}{,} \PYG{n}{k}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{:}
        \PYG{c+c1}{\PYGZsh{} Contrastive Divergence (CD\PYGZhy{}k) algorithm for training the RBM, Gibbs sampling}
