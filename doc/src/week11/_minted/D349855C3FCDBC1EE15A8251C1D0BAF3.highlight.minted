        \PYG{n}{prob\PYGZus{}h} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{sigmoid}\PYG{p}{(}\PYG{n}{activation}\PYG{p}{)}
        \PYG{k}{return} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{binomial}\PYG{p}{(}\PYG{n}{n}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{p}\PYG{o}{=}\PYG{n}{prob\PYGZus{}h}\PYG{p}{)}\PYG{p}{,} \PYG{n}{prob\PYGZus{}h}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{sample\PYGZus{}visible}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{h}\PYG{p}{)}\PYG{p}{:}
