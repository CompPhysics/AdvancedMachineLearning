\section{Boltzmann machines}
%================================================

\begin{frame}{Boltzmann Machines}
A Boltzmann machine is a probabilistic model with energy
\[
E(v,h)
=
-\sum_i a_i v_i
-\sum_j b_j h_j
-\sum_{i,j} W_{ij} v_i h_j
-\sum_{i<j} U_{ij} v_i v_j
-\sum_{j<k} V_{jk} h_j h_k,
\]
where:
\begin{itemize}
    \item \(v\) are visible units,
    \item \(h\) are hidden units.
\end{itemize}

The joint distribution is
\[
p(v,h)=\frac{1}{Z}e^{-E(v,h)}.
\]

Sampling from this distribution is naturally done by Gibbs updates.
\end{frame}

\begin{frame}{Restricted Boltzmann Machines}
For a restricted Boltzmann machine (RBM), there are no intra-layer couplings:
\[
E(v,h)
=
-\sum_i a_i v_i
-\sum_j b_j h_j
-\sum_{i,j} W_{ij} v_i h_j.
\]

This bipartite structure implies conditional factorization:
\[
p(h\mid v)=\prod_j p(h_j\mid v),
\qquad
p(v\mid h)=\prod_i p(v_i\mid h).
\]

That is why Gibbs sampling is especially efficient for RBMs.
\end{frame}

\begin{frame}{RBM Conditional Distributions}
For binary RBM units \(v_i,h_j\in\{0,1\}\),
\[
p(h_j=1\mid v)=\sigma\left(b_j+\sum_i W_{ij}v_i\right),
\]
\[
p(v_i=1\mid h)=\sigma\left(a_i+\sum_j W_{ij}h_j\right),
\]
where
\[
\sigma(x)=\frac{1}{1+e^{-x}}.
\]

So Gibbs sampling alternates:
\[
v \to h \to v \to h \to \cdots
\]

This is the basis of contrastive divergence and related learning procedures.
\end{frame}

\begin{frame}{Why Gibbs Sampling is Useful in Boltzmann Machines}
Training requires expectations such as
\[
\mathbb{E}_{p(v,h)}[v_i h_j],
\]
which are generally intractable exactly.

Gibbs sampling is used to estimate these expectations by MCMC.

For RBMs, block Gibbs is particularly natural:
\begin{itemize}
    \item sample all hidden units in parallel given visibles,
    \item sample all visible units in parallel given hiddens.
\end{itemize}
\end{frame}

