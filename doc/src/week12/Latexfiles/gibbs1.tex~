\section{Convergence, mixing, autocorrelation}
%================================================

\begin{frame}{Convergence Conditions}
To conclude convergence to \(\pi\), one usually requires:
\begin{itemize}
    \item irreducibility,
    \item aperiodicity,
    \item positive recurrence.
\end{itemize}

Under these conditions,
\[
\lim_{t\to\infty}\mathbb{P}(X^{(t)}\in A)=\pi(A).
\]

So the chain forgets its initial condition and approaches equilibrium.
\end{frame}

\begin{frame}{Ergodic Theorem}
If the chain is ergodic and \(f\in L^1(\pi)\), then
\[
\frac{1}{N}\sum_{t=1}^N f(X^{(t)})
\longrightarrow
\mathbb{E}_{\pi}[f]
\]
almost surely.

This is why MCMC is useful in practice: we estimate expectations under \(\pi\) by time averages.
\end{frame}

\begin{frame}{Autocorrelation Function}
Samples in MCMC are correlated. For an observable \(f(X_t)\), define the autocovariance
\[
\Gamma_f(k)=\mathrm{Cov}_\pi(f(X_t),f(X_{t+k})).
\]

The normalized autocorrelation is
\[
\rho_f(k)=\frac{\Gamma_f(k)}{\Gamma_f(0)}.
\]

If \(\rho_f(k)\) decays slowly, then the chain mixes slowly and effective sampling is poor.
\end{frame}

\begin{frame}{Integrated Autocorrelation Time}
Define the integrated autocorrelation time
\[
\tau_{\mathrm{int}}(f)=1+2\sum_{k=1}^{\infty}\rho_f(k),
\]
provided the sum converges.

Then the variance of the empirical mean behaves like
\[
\mathrm{Var}\left(\frac{1}{N}\sum_{t=1}^N f(X_t)\right)
\approx
\frac{\Gamma_f(0)}{N}\tau_{\mathrm{int}}(f).
\]

Thus the effective sample size is roughly
\[
N_{\mathrm{eff}}\approx \frac{N}{\tau_{\mathrm{int}}(f)}.
\]
\end{frame}

\begin{frame}{Mixing Time}
A rough notion of mixing time is the number of steps needed for the chain to get close to equilibrium.

Formally, one may define
\[
t_{\mathrm{mix}}(\varepsilon)
=
\min\left\{
t:\sup_x \norm{K^t(x,\cdot)-\pi}_{\mathrm{TV}}\le \varepsilon
\right\},
\]
where total variation distance is
\[
\norm{\mu-\nu}_{\mathrm{TV}}
=
\sup_A |\mu(A)-\nu(A)|.
\]

Small mixing time means rapid equilibration.
\end{frame}

\begin{frame}{Why Gibbs Sampling Can Mix Slowly}
Gibbs sampling may be slow if:
\begin{itemize}
    \item variables are strongly correlated,
    \item the target is multimodal,
    \item local updates change the state only slightly,
    \item the system is near a critical point.
\end{itemize}

In statistical physics this becomes critical slowing down.

Near a phase transition, local updates often decorrelate very slowly, so both \(\tau_{\mathrm{int}}\) and \(t_{\mathrm{mix}}\) become large.
\end{frame}

\begin{frame}{Blocked Gibbs Sampling}
To improve mixing, one may update a block \(x_B\) at once:
\[
x_B^{(t+1)}\sim \pi(x_B\mid x_{-B}^{(t)}).
\]

This preserves the Gibbs philosophy but can reduce autocorrelation dramatically when variables in a block are strongly coupled.

Examples:
\begin{itemize}
    \item block spin updates,
    \item latent Gaussian blocks in Bayesian models,
    \item visible/hidden layers in Boltzmann machines.
\end{itemize}
\end{frame}

