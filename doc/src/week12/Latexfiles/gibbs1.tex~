\begin{frame}{Goals of These Notes}
These notes develop Gibbs sampling with proper mathematics and add four further topics:
\begin{itemize}
    \item comparison with Metropolis sampling,
    \item autocorrelation times and mixing,
    \item Gibbs sampling in Boltzmann machines,
    \item Gibbs sampling in Bayesian networks and graphical models.
\end{itemize}

The aim is to explain both the mathematical correctness and the practical strengths and limitations of Gibbs sampling.
\end{frame}

%================================================
\section{The basic problem}
%================================================

\begin{frame}{The Sampling Problem}
We want to sample from a probability distribution
\[
\pi(x_1,\dots,x_d)
\]
on a high-dimensional state space.

Typical examples:
\begin{itemize}
    \item Boltzmann distributions in statistical mechanics,
    \item posterior distributions in Bayesian inference,
    \item latent-variable models in machine learning.
\end{itemize}

Usually:
\begin{itemize}
    \item \(\pi\) is known only up to normalization,
    \item direct sampling is hard,
    \item conditional distributions are tractable.
\end{itemize}
\end{frame}

\begin{frame}{Normalized and Unnormalized Form}
Often
\[
\pi(x)=\frac{1}{Z}f(x),
\]
where
\[
Z=\int f(x)\,dx
\quad\text{or}\quad
Z=\sum_x f(x).
\]

In statistical physics one writes
\[
\pi(x)=\frac{1}{Z}e^{-\beta E(x)}.
\]

The partition function \(Z\) is usually difficult to compute, but Gibbs sampling does not require \(Z\) explicitly.
\end{frame}

\begin{frame}{Conditional Distributions}
For a coordinate \(i\), define
\[
\pi(x_i\mid x_{-i})
=
\frac{\pi(x_i,x_{-i})}{\int \pi(x_i',x_{-i})\,dx_i'}.
\]

Here \(x_{-i}\) denotes all coordinates except \(x_i\).

The core idea of Gibbs sampling is:
\[
\text{sample one variable at a time from its exact conditional law.}
\]
\end{frame}

\begin{frame}{Gibbs Update Rule}
Let
\[
x^{(t)}=(x_1^{(t)},\dots,x_d^{(t)}).
\]

A deterministic Gibbs sweep updates
\[
x_1^{(t+1)} \sim \pi(x_1\mid x_2^{(t)},\dots,x_d^{(t)}),
\]
\[
x_2^{(t+1)} \sim \pi(x_2\mid x_1^{(t+1)},x_3^{(t)},\dots,x_d^{(t)}),
\]
and so on until
\[
x_d^{(t+1)} \sim \pi(x_d\mid x_1^{(t+1)},\dots,x_{d-1}^{(t+1)}).
\]

This defines a Markov chain.
\end{frame}

\begin{frame}{Single-Coordinate Transition Kernel}
A single-coordinate Gibbs update for coordinate \(i\) defines
\[
K_i(x,dx')=\delta_{x_{-i}}(dx'_{-i})\,\pi(dx_i'\mid x_{-i}).
\]

Interpretation:
\begin{itemize}
    \item all other coordinates remain fixed,
    \item coordinate \(i\) is resampled exactly.
\end{itemize}

A full sweep is the composition
\[
K=K_d\cdots K_2K_1.
\]
\end{frame}

%================================================
\section{Correctness}
%================================================

\begin{frame}{Invariant Distribution}
We want to show that \(\pi\) is invariant:
\[
\int \pi(dx)\,K(x,A)=\pi(A)
\]
for every measurable set \(A\).

It is enough to prove invariance for each \(K_i\), since compositions of invariant kernels remain invariant.
\end{frame}

\begin{frame}{Proof of Invariance for One Coordinate}
For one coordinate update,
\[
\int \pi(dx)\,K_i(x,dx')
=
\int \pi(dx_i,dx_{-i})\,\delta_{x_{-i}}(dx'_{-i})\,\pi(dx'_i\mid x_{-i}).
\]

Factorize
\[
\pi(dx_i,dx_{-i})=\pi(dx_i\mid x_{-i})\,\pi_{-i}(dx_{-i}).
\]

Integrating over \(x_i\),
\[
\int \pi(dx_i\mid x_{-i})=1.
\]

Hence
\[
\int \pi(dx)\,K_i(x,dx')
=
\pi(dx'_i\mid x'_{-i})\,\pi_{-i}(dx'_{-i})
=
\pi(dx').
\]

So \(\pi\) is invariant.
\end{frame}

\begin{frame}{Detailed Balance}
A single-coordinate Gibbs update satisfies
\[
\pi(dx)\,K_i(x,dx')=\pi(dx')\,K_i(x',dx).
\]

Indeed, if \(x_{-i}\neq x'_{-i}\), both sides vanish. If \(x_{-i}=x'_{-i}\), then
\[
\pi(x)\,K_i(x,x')
=
\pi(x_i,x_{-i})\,\pi(x'_i\mid x_{-i}),
\]
and
\[
\pi(x')\,K_i(x',x)
=
\pi(x'_i,x_{-i})\,\pi(x_i\mid x_{-i}).
\]

Using
\[
\pi(x_i,x_{-i})=\pi(x_i\mid x_{-i})\pi(x_{-i}),
\]
both sides coincide.
\end{frame}

\begin{frame}{Why Detailed Balance Matters}
Detailed balance implies invariance:
\[
\pi(dx)\,K(x,dx')=\pi(dx')\,K(x',dx)
\quad\Longrightarrow\quad
\pi K=\pi.
\]

This is the equilibrium flux condition: probability current from \(x\) to \(x'\) balances the reverse current.

For Gibbs sampling:
\begin{itemize}
    \item each coordinate update is reversible,
    \item random-scan Gibbs is reversible,
    \item deterministic sweep is invariant though not always strictly reversible as a whole.
\end{itemize}
\end{frame}

\begin{frame}{Random-Scan Gibbs}
If we choose coordinate \(I_t\in\{1,\dots,d\}\) randomly with
\[
\mathbb{P}(I_t=i)=p_i,\qquad \sum_i p_i=1,
\]
then the transition kernel is
\[
K=\sum_{i=1}^d p_i K_i.
\]

Since each \(K_i\) leaves \(\pi\) invariant, so does \(K\):
\[
\pi K=\sum_{i=1}^d p_i\,\pi K_i=\sum_{i=1}^d p_i\,\pi=\pi.
\]
\end{frame}

