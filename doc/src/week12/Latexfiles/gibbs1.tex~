\section{Gibbs vs Metropolis}
%================================================

\begin{frame}{Metropolis--Hastings Recap}
Metropolis--Hastings proposes \(x\to x'\) from proposal density \(q(x'\mid x)\), then accepts with probability
\[
\alpha(x,x')=
\min\left(
1,\frac{\pi(x')q(x\mid x')}{\pi(x)q(x'\mid x)}
\right).
\]

This ensures detailed balance with respect to \(\pi\).
\end{frame}

\begin{frame}{Gibbs as a Special Case of Metropolis--Hastings}
In Gibbs sampling, the proposal for coordinate \(i\) is exactly the conditional:
\[
q(x_i'\mid x)=\pi(x_i'\mid x_{-i}).
\]

Then, for states differing only in coordinate \(i\),
\[
\frac{\pi(x')q(x\mid x')}{\pi(x)q(x'\mid x)}
=
\frac{\pi(x_i',x_{-i})\,\pi(x_i\mid x_{-i})}{\pi(x_i,x_{-i})\,\pi(x_i'\mid x_{-i})}=1.
\]

So Gibbs is a rejection-free Metropolis--Hastings method.
\end{frame}

\begin{frame}{Conceptual Difference: Gibbs vs Metropolis}
\textbf{Gibbs sampling}
\begin{itemize}
    \item uses exact conditional distributions,
    \item every move is accepted,
    \item requires tractable conditionals.
\end{itemize}

\textbf{Metropolis sampling}
\begin{itemize}
    \item works with arbitrary proposals,
    \item may reject moves,
    \item often easier to apply when conditionals are unavailable.
\end{itemize}

Thus Gibbs is more specialized but often more efficient when exact conditionals are known.
\end{frame}

\begin{frame}{Example: Local Metropolis vs Gibbs in the Ising Model}
For Ising spins \(s_i\in\{-1,+1\}\):
\begin{itemize}
    \item local Metropolis proposes \(s_i\to -s_i\) and accepts/rejects,
    \item Gibbs directly samples \(s_i\) from its conditional distribution.
\end{itemize}

Metropolis:
\[
\alpha=\min(1,e^{-\beta \Delta E}).
\]

Gibbs:
\[
\mathbb{P}(s_i=+1\mid s_{-i})
=
\frac{1}{1+e^{-2\beta H_i^{\mathrm{loc}}}}.
\]

So Gibbs can be viewed as sampling the exact thermal distribution at a site, rather than flipping a site with an accept/reject rule.
\end{frame}

%================================================
\section{Examples}
%================================================

\begin{frame}{Boltzmann Distribution}
Suppose
\[
\pi(x)=\frac{1}{Z}e^{-\beta E(x)}.
\]

Then
\[
\pi(x_i\mid x_{-i})
=
\frac{e^{-\beta E(x_i,x_{-i})}}
{\sum_{x_i'}e^{-\beta E(x_i',x_{-i})}}
\]
in the discrete case.

So Gibbs sampling is local equilibrium sampling in a frozen environment.
\end{frame}

\begin{frame}{Ising Model}
For spins \(s_i\in\{-1,+1\}\), energy
\[
E(s)=-\sum_{\langle i,j\rangle}J_{ij}s_i s_j-\sum_i h_i s_i.
\]

The local field at site \(i\) is
\[
H_i^{\mathrm{loc}}=\sum_{j\neq i}J_{ij}s_j+h_i.
\]

Then
\[
\pi(s_i\mid s_{-i})\propto e^{\beta s_i H_i^{\mathrm{loc}}}.
\]

Hence
\[
\mathbb{P}(s_i=+1\mid s_{-i})
=
\frac{1}{1+e^{-2\beta H_i^{\mathrm{loc}}}},
\]
\[
\mathbb{P}(s_i=-1\mid s_{-i})
=
\frac{1}{1+e^{2\beta H_i^{\mathrm{loc}}}}.
\]
\end{frame}

\begin{frame}{Continuous Example: Bivariate Gaussian}
Let
\[
\begin{pmatrix}X\\Y\end{pmatrix}
\sim\mathcal{N}\left(
\begin{pmatrix}\mu_X\\\mu_Y\end{pmatrix},
\begin{pmatrix}
\sigma_X^2 & \rho\sigma_X\sigma_Y\\
\rho\sigma_X\sigma_Y & \sigma_Y^2
\end{pmatrix}
\right).
\]

Then
\[
X\mid Y=y \sim
\mathcal{N}\left(
\mu_X+\rho\frac{\sigma_X}{\sigma_Y}(y-\mu_Y),
\ \sigma_X^2(1-\rho^2)
\right),
\]
\[
Y\mid X=x \sim
\mathcal{N}\left(
\mu_Y+\rho\frac{\sigma_Y}{\sigma_X}(x-\mu_X),
\ \sigma_Y^2(1-\rho^2)
\right).
\]

So Gibbs alternates exact Gaussian draws.
\end{frame}

