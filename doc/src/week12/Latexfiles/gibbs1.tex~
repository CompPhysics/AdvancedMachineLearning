\section{Bayesian networks and graphical models}
%================================================

\begin{frame}{Bayesian Networks}
A Bayesian network is a directed acyclic graphical model with factorization
\[
p(x_1,\dots,x_d)=\prod_{i=1}^d p(x_i\mid \mathrm{pa}(x_i)),
\]
where \(\mathrm{pa}(x_i)\) denotes the parents of node \(x_i\).

When conditioning on observed evidence, the posterior can become difficult to sample from directly.

Gibbs sampling provides a way to sample each latent variable from its conditional distribution given the rest.
\end{frame}

\begin{frame}{Local Markov Blanket}
In a Bayesian network, the conditional of a node depends only on its Markov blanket:
\[
p(x_i\mid x_{-i}) = p(x_i\mid \mathrm{MB}(x_i)).
\]

The Markov blanket \(\mathrm{MB}(x_i)\) contains:
\begin{itemize}
    \item the parents of \(x_i\),
    \item the children of \(x_i\),
    \item the co-parents of those children.
\end{itemize}

This locality makes Gibbs sampling computationally efficient in sparse graphical models.
\end{frame}

\begin{frame}{Gibbs Sampling in Bayesian Networks}
To update node \(x_i\), compute
\[
p(x_i\mid x_{-i})\propto p(x_i\mid \mathrm{pa}(x_i))
\prod_{y\in \mathrm{ch}(x_i)} p(y\mid \mathrm{pa}(y)),
\]
where \(\mathrm{ch}(x_i)\) are the children of \(x_i\).

Thus only local factors are needed.

This is the graphical-model analogue of the local Boltzmann update in statistical mechanics.
\end{frame}

\begin{frame}{Graphical Models: Physical Analogy}
There is a strong analogy:
\begin{itemize}
    \item in spin systems, a variable interacts only with neighbors,
    \item in Bayesian networks, a variable depends only on its local Markov blanket.
\end{itemize}

In both cases, Gibbs sampling exploits locality:
\[
\text{global equilibrium distribution}
\quad\Longleftrightarrow\quad
\text{repeated local conditional updates}.
\]
\end{frame}

